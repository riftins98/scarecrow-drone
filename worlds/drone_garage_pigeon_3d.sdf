      <link name="link"><visual name="v">
        <geometry><box><size>0.08 3.0 0.002</size></box></geometry>
        <material><ambient>1.0 0.85 0.0 1</ambient><diffuse>1.0 0.85 0.0 1</diffuse></material>
      </visual></link>
    </model>

    <!-- ==================== LANDING PAD 2 (RQ-7B Shadow footprint) ==================== -->
    <model name="pad_2_ring">
      <static>true</static><pose>5 0 0.003 0 0 0</pose>
      <link name="link"><visual name="v">
        <geometry><cylinder><radius>4.0</radius><length>0.002</length></cylinder></geometry>
        <material><ambient>1.0 0.85 0.0 1</ambient><diffuse>1.0 0.85 0.0 1</diffuse></material>
      </visual></link>
    </model>
    <model name="pad_2_fill">
