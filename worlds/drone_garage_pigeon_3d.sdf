      <static>true</static><pose>-12.1 0 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.2 15.4 3.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.2 15.4 3.0</size></box></geometry>
          <material><ambient>0.50 0.50 0.50 1</ambient><diffuse>0.50 0.50 0.50 1</diffuse></material></visual>
      </link>
    </model>
    <!-- East wall (Y=+7.5) -->
    <model name="wall_east">
      <static>true</static><pose>0 7.6 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>24.0 0.2 3.0</size></box></geometry></collision>
