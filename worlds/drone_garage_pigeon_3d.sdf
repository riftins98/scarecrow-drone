    <!-- ==================== WALLS & CEILING (20m x 15m x 3m) ==================== -->
    <!-- North wall (X=+10) -->
    <model name="wall_north">
      <static>true</static><pose>12.1 0 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.2 15.4 3.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.2 15.4 3.0</size></box></geometry>
