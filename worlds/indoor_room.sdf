<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.9">
  <world name="indoor_room">
    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>
    <scene>
      <grid>false</grid>
      <ambient>0.5 0.5 0.5 1</ambient>
      <background>0.2 0.2 0.3 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- ==================== FLOOR ==================== -->
    <!-- Collision ground plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>1 1</size></plane></geometry>
          <surface><friction><ode/></friction></surface>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.3 0.3 0.3 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Checkerboard floor tiles (8x8 grid, 0.5m tiles) for optical flow -->
    <model name="floor_tiles">
      <static>true</static>
      <pose>0 0 0.001 0 0 0</pose>
      <link name="tiles">
        <!-- Generate 8x8 checkerboard centered on origin -->
        <!-- Row 0 -->
        <visual name="t00"><pose>-1.75 -1.75 0 0 0 0</pose><geometry><box><size>0.5 0.5 0.001</size></box></geometry><material><diffuse>0.9 0.9 0.9 1</diffuse></material></visual>
        <visual name="t01"><pose>-1.75 -1.25 0 0 0 0</pose><geometry><box><size>0.5 0.5 0.001</size></box></geometry><material><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
