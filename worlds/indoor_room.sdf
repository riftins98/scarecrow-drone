    <!-- ==================== WALLS (20m x 20m room, 3m tall, no ceiling) ==================== -->

    <!-- North wall — RED -->
    <model name="wall_north">
      <static>true</static>
      <pose>10 0 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.1 20 3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 20 3</size></box></geometry>
          <material><diffuse>0.85 0.15 0.15 1</diffuse><ambient>0.85 0.15 0.15 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- South wall — BLUE -->
    <model name="wall_south">
      <static>true</static>
      <pose>-10 0 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.1 20 3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.1 20 3</size></box></geometry>
          <material><diffuse>0.15 0.25 0.85 1</diffuse><ambient>0.15 0.25 0.85 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- East wall — GREEN -->
    <model name="wall_east">
      <static>true</static>
      <pose>0 10 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>20 0.1 3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>20 0.1 3</size></box></geometry>
          <material><diffuse>0.15 0.75 0.25 1</diffuse><ambient>0.15 0.75 0.25 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- West wall — YELLOW -->
    <model name="wall_west">
      <static>true</static>
      <pose>0 -10 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>20 0.1 3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>20 0.1 3</size></box></geometry>
          <material><diffuse>0.9 0.85 0.1 1</diffuse><ambient>0.9 0.85 0.1 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ==================== OBSTACLES ==================== -->

    <!-- Cylinder pillar — WHITE, in front-right -->
    <model name="pillar">
      <static>true</static>
      <pose>2.0 2.0 0.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.3</radius><length>1.5</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.3</radius><length>1.5</length></cylinder></geometry>
          <material><diffuse>0.95 0.95 0.95 1</diffuse><ambient>0.95 0.95 0.95 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- L-shaped wall — ORANGE, behind-left -->
    <model name="l_wall_part1">
      <static>true</static>
      <pose>-2.0 -1.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>2.0 0.15 1.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>2.0 0.15 1.0</size></box></geometry>
          <material><diffuse>0.9 0.5 0.1 1</diffuse><ambient>0.9 0.5 0.1 1</ambient></material>
        </visual>
      </link>
    </model>
    <model name="l_wall_part2">
      <static>true</static>
      <pose>-1.075 -2.25 0.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.15 1.5 1.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.15 1.5 1.0</size></box></geometry>
          <material><diffuse>0.9 0.5 0.1 1</diffuse><ambient>0.9 0.5 0.1 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- Wedge/ramp — PURPLE, front-left -->
    <model name="ramp">
      <static>true</static>
      <pose>2.0 -2.0 0 0 0 0</pose>
      <link name="link">
        <collision name="c">
          <pose>0 0 0.25 0 0 0</pose>
          <geometry><box><size>1.0 1.0 0.5</size></box></geometry>
        </collision>
        <visual name="v">
          <pose>0 0 0.25 0 0 0</pose>
          <geometry><box><size>1.0 1.0 0.5</size></box></geometry>
          <material><diffuse>0.6 0.2 0.8 1</diffuse><ambient>0.6 0.2 0.8 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- Small box stack — TEAL, near center -->
    <model name="box_small">
      <static>true</static>
      <pose>0.8 -0.5 0.2 0 0 0.3</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.4 0.4 0.4</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.4 0.4 0.4</size></box></geometry>
          <material><diffuse>0.1 0.7 0.7 1</diffuse><ambient>0.1 0.7 0.7 1</ambient></material>
        </visual>
      </link>
    </model>
    <model name="box_top">
      <static>true</static>
      <pose>0.8 -0.5 0.55 0 0 0.6</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.3 0.3 0.3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <material><diffuse>0.1 0.5 0.5 1</diffuse><ambient>0.1 0.5 0.5 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ==================== LIGHTING ==================== -->

    <!-- Ceiling light (bright, centered) -->
    <light name="ceiling_light" type="point">
      <pose>0 0 2.4 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1.5</intensity>
      <diffuse>1.0 0.95 0.9 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <attenuation>
        <range>15</range>
        <linear>0.05</linear>
        <constant>0.8</constant>
        <quadratic>0.01</quadratic>
      </attenuation>
    </light>

    <!-- Secondary fill light -->
    <light name="fill_light" type="directional">
      <pose>0 0 5 0 0 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>0.5</intensity>
      <direction>0.1 0.1 -1</direction>
      <diffuse>0.8 0.8 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
    </light>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>47.397971057728974</latitude_deg>
      <longitude_deg>8.546163739800146</longitude_deg>
      <elevation>0</elevation>
    </spherical_coordinates>
