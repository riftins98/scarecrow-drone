    <!--
      12m x 8m x 8m lightweight shell.
      Aligned to preserve hangar_1 stream-spawn geometry at PX4_GZ_MODEL_POSE=5,-4.5,0:
      - front (+X) distance = 7.0m
      - right (-Y) distance = 3.0m
    -->

    <!-- ==================== FLOOR (12m x 8m) ==================== -->
