        <visual name="t_11_07"><pose>11.5 0.0 0 0 0 0</pose><geometry><box><size>1 1 0.001</size></box></geometry><material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ==================== WALLS & CEILING (12m x 8m x 8m) ==================== -->
    <!-- Interior X range: [0.0, 12.0], interior Y range: [-7.5, 0.5] -->
    <model name="wall_north">
      <static>true</static><pose>12.1 -3.5 4.0 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.2 8.4 8.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.2 8.4 8.0</size></box></geometry>
          <material><ambient>0.42 0.44 0.45 1</ambient><diffuse>0.42 0.44 0.45 1</diffuse><specular>0.12 0.12 0.12 1</specular></material></visual>
      </link>
    </model>

    <model name="wall_south">
      <static>true</static><pose>-0.1 -3.5 4.0 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.2 8.4 8.0</size></box></geometry></collision>
        <visual name="v">
          <transparency>0.78</transparency>
          <geometry><box><size>0.2 8.4 8.0</size></box></geometry>
          <material><ambient>0.42 0.44 0.45 0.22</ambient><diffuse>0.42 0.44 0.45 0.22</diffuse><specular>0.12 0.12 0.12 0.22</specular></material></visual>
      </link>
    </model>

    <model name="wall_east">
      <static>true</static><pose>6 0.6 4.0 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>12.0 0.2 8.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>12.0 0.2 8.0</size></box></geometry>
          <material><ambient>0.42 0.44 0.45 1</ambient><diffuse>0.42 0.44 0.45 1</diffuse><specular>0.12 0.12 0.12 1</specular></material></visual>
      </link>
    </model>

    <model name="wall_west">
      <static>true</static><pose>6 -7.6 4.0 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>12.0 0.2 8.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>12.0 0.2 8.0</size></box></geometry>
          <material><ambient>0.42 0.44 0.45 1</ambient><diffuse>0.42 0.44 0.45 1</diffuse><specular>0.12 0.12 0.12 1</specular></material></visual>
      </link>
    </model>

    <model name="ceiling">
      <static>true</static><pose>6 -3.5 7.95 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>12.0 8.0 0.1</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>12.0 8.0 0.1</size></box></geometry>
          <material>
            <ambient>0.62 0.62 0.65 1</ambient>
            <diffuse>0.62 0.62 0.65 1</diffuse>
            <specular>0.03 0.03 0.03 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== LIGHTING ==================== -->
    <light name="light_bay_1" type="point">
      <pose>4 -3.5 7.8 0 0 0</pose><cast_shadows>false</cast_shadows>
      <intensity>1.3</intensity><diffuse>1.0 1.0 1.0 1</diffuse><specular>0.3 0.3 0.3 1</specular>
      <attenuation><range>14</range><linear>0.05</linear><constant>0.6</constant><quadratic>0.01</quadratic></attenuation>
    </light>

    <light name="light_bay_2" type="point">
      <pose>8 -3.5 7.8 0 0 0</pose><cast_shadows>false</cast_shadows>
      <intensity>1.3</intensity><diffuse>1.0 1.0 1.0 1</diffuse><specular>0.3 0.3 0.3 1</specular>
      <attenuation><range>14</range><linear>0.05</linear><constant>0.6</constant><quadratic>0.01</quadratic></attenuation>
    </light>

    <!-- Target centered east-west and 1.5m from the north wall -->
    <include>
      <uri>model://pigeon_3d</uri>
      <name>pigeon_1</name>
      <!--  North wall position -->
      <pose>10.5 -3.5 2.5 0 0 0</pose>
    </include>

    <include>
      <uri>model://pigeon_3d</uri>
      <name>pigeon_2</name>
      <!-- East/South wall position -->
      <pose>2.5 -6 2.5 0 0 0</pose>
    </include>

    <include>
      <uri>model://mono_cam_hd</uri>
      <name>fixed_cam</name>
      <pose>1 -4.5 2 0 0 0</pose>
      <static>true</static>
    </include>

    <include>
      <uri>model://mono_cam_hd</uri>
      <name>center_cam</name>
      <pose>6 -3.5 7.7 0 1.5708 0</pose>
      <static>true</static>
    </include>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <latitude_deg>0</latitude_deg>
      <longitude_deg>0</longitude_deg>
      <elevation>0</elevation>
    </spherical_coordinates>
  </world>
</sdf>
