#!/bin/sh
#
# @name Holybro X500 V2 — GPS-denied with full sensor stack
# @type Quadrotor
#
# Sensors: optical flow (MTF-01), rangefinder (TF-Luna), 2D lidar (RPLidar A1M8), mono camera (Pi Camera 3)
# Based on stock 4021_gz_x500_flow — only GPS disabled, everything else at PX4 defaults.
#

PX4_SIM_MODEL=${PX4_SIM_MODEL:=holybro_x500}

. ${R}etc/init.d-posix/airframes/4001_gz_x500

# GPS disabled — indoor GPS-denied flight
param set-default SYS_HAS_GPS 0
param set-default SIM_GPS_USED 0
param set-default EKF2_GPS_CTRL 0
param set-default EKF2_MAG_TYPE 5
param set-default EKF2_HGT_REF 0

# Allow arming without GPS
param set-default COM_ARM_WO_GPS 1
param set-default COM_RC_IN_MODE 1
param set-default NAV_DLL_ACT 0
param set-default NAV_RCL_ACT 0
